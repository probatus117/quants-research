# Stock-Skills v2 Environment Variables
# Copy to .env and fill in your values.
# All variables are optional — the system works without any API keys.

# --- Neo4j (GraphRAG) ---
# Optional: enables knowledge graph for past analysis/lesson storage
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_MODE=full                # off / summary / full

# --- TEI (Text Embeddings Inference) ---
# Optional: enables vector search for semantic queries
TEI_URL=http://localhost:8081

# --- Grok API (xAI) ---
# Optional: enables X sentiment analysis, news search, trend detection
# Get your API key from https://console.x.ai/
XAI_API_KEY=

# --- Gemini API (Google) ---
# Optional: enables multi-LLM review (logic reviewer)
GEMINI_API_KEY=

# --- OpenAI API ---
# Optional: enables multi-LLM review (risk reviewer)
OPENAI_API_KEY=
